"""
AutoMCP Generated Tool
name:     {{ spec.tool_name }}
purpose:  {{ spec.purpose }}
method:   {{ spec.method }}
url:      {{ spec.url_template }}
auth:     {{ spec.auth_strategy }}
"""
from __future__ import annotations

from typing import Any

import httpx

from core.runtime.middleware import RetryConfig, ToolError, with_retry


{% if spec.inputs %}
# ── Inputs ────────────────────────────────────────────────────────────────────
{% for inp in spec.inputs | sort(attribute='required', reverse=True) %}
# {{ inp.name }} ({{ inp.type }}{% if not inp.required %}, optional{% endif %}{% if inp.description %}) — {{ inp.description }}{% else %}){% endif %}

{% endfor %}
{% endif %}

async def {{ spec.tool_name }}(
{% for inp in spec.inputs | sort(attribute='required', reverse=True) %}
    {{ inp.name }}: {{ inp.type | python_type }}{% if not inp.required %} | None = None{% endif %},
{% endfor %}
    _cookies: dict[str, str] | None = None,
    _headers: dict[str, str] | None = None,
) -> Any:
    """{{ spec.purpose }}

    URL: {{ spec.url_template }}
    Method: {{ spec.method }}
    Auth: {{ spec.auth_strategy }}
    """
    base_headers: dict[str, str] = {
        "Content-Type": "application/json",
        "Accept": "application/json",
    }
    if _headers:
        base_headers.update(_headers)

{% if spec.auth_strategy == "cookies" %}
    if _cookies:
        base_headers["Cookie"] = "; ".join(f"{k}={v}" for k, v in _cookies.items())
{% elif spec.auth_strategy == "bearer" %}
    if _headers and "Authorization" in _headers:
        base_headers["Authorization"] = _headers["Authorization"]
{% elif spec.auth_strategy == "api_key" %}
    if _headers and "X-Api-Key" in _headers:
        base_headers["X-Api-Key"] = _headers["X-Api-Key"]
{% endif %}

    # Build request payload from spec mapping
    body: dict[str, Any] = {}
{% for target, source in spec.request_mapping.items() %}
{% if source.startswith("$input.") %}
    if {{ source[7:] }} is not None:
        body["{{ target }}"] = {{ source[7:] }}
{% endif %}
{% endfor %}

    async def _call() -> Any:
        async with httpx.AsyncClient(timeout=30.0) as client:
            response = await client.{{ spec.method | lower }}(
                "{{ spec.url_template }}",
{% if spec.method | upper in ["POST", "PUT", "PATCH"] %}
                json=body if body else None,
{% elif spec.method | upper in ["GET", "DELETE"] and spec.request_mapping %}
                params={k: v for k, v in body.items() if v is not None},
{% endif %}
                headers=base_headers,
                follow_redirects=True,
            )
            if response.status_code in (401, 403):
                raise ToolError(
                    f"Authentication failed (HTTP {response.status_code}). "
                    "Re-record the session with `automcp record` to refresh credentials.",
                    status_code=response.status_code,
                    retryable=False,
                )
            response.raise_for_status()
{% if spec.response_type == "json" %}
            return response.json()
{% else %}
            return response.text
{% endif %}

    return await with_retry(_call, RetryConfig(max_attempts=3))
